    }
    for (int i=0;i<NUM_BOWLERS;i++) {
        auto& bw = team_bowlers[bf][i];
        bw.overs_bowled=0; bw.runs_given=0; bw.wickets_taken=0;
        bw.economy=0.0; bw.saved_balls=0;
    }
    match_state.last_over_runs           = 0;
    match_state.free_hit                 = false;
    match_state.innings_over[bowl_first] = false;

    // Innings 2
    pthread_t inn2;
    InningsArg* ia2 = new InningsArg{bowl_first, bf, target, schd};
    pthread_create(&inn2, nullptr, simulateInnings, ia2);
    pthread_join(inn2, nullptr);

    printResult(bf);
    printDotGanttChart();
    printWaitTimeAnalysis(bf);

    // Cleanup
    rag.destroy();
    sem_destroy(&crease_sem);
    pthread_mutex_destroy(&pitch_mutex);
    pthread_mutex_destroy(&score_mutex);
    pthread_mutex_destroy(&log_mutex);
    pthread_mutex_destroy(&runout_mutex);
    pthread_mutex_destroy(&gantt_mutex);
    pthread_cond_destroy(&ball_hit_cond);
    return 0;
}
