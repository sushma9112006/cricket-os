    if (randomBit()) { cout << twn << " elected to BAT.\n";  bf = tw; }
    else             { cout << twn << " elected to BOWL.\n"; bf = 1-tw; }
    int bowl_first = 1 - bf;

    // Innings 1
    pthread_t inn1;
    InningsArg* ia1 = new InningsArg{bf, bowl_first, 0, schd};
    pthread_create(&inn1, nullptr, simulateInnings, ia1);
    pthread_join(inn1, nullptr);
