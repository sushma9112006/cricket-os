// RUN-OUT DEADLOCK DETECTION  (RAG-based)


int checkRunOut(int bat_team, int ba, int bb, int field_team) {
    if (ba < 0 || bb < 0 || ba >= NUM_BATTERS || bb >= NUM_BATTERS || ba == bb)
        return -1;

    pthread_mutex_lock(&runout_mutex);

    BatterStats& a = team_batters[bat_team][ba];
    BatterStats& b = team_batters[bat_team][bb];

    if (!a.at_crease || !b.at_crease || a.is_out || b.is_out) {
        pthread_mutex_unlock(&runout_mutex);
        return -1;
    }

    int end_a = (a.crease_end == 0) ? 1 : 0;
    int end_b = b.crease_end;

    if (end_a == end_b) {
        rag.request(ba, end_a);
        rag.request(bb, end_b);

        pthread_mutex_lock(&log_mutex);
        cout << "  [RAG] Run-out attempt: "
             << a.name << " and " << b.name
             << " both heading to end " << end_a
             << " — checking for deadlock cycle...\n";
        cout<<endl;
        cout<<endl;
        pthread_mutex_unlock(&log_mutex);
    }

    int cycle[2] = {-1, -1};
    if (!rag.detectCycle(cycle)) {
        pthread_mutex_unlock(&runout_mutex);
        return -1;
    }

    BatterStats& x = team_batters[bat_team][cycle[0]];
    BatterStats& y = team_batters[bat_team][cycle[1]];

    double cost_x = x.strike_rate * (1.0 + x.runs_scored / 10.0);
    double cost_y = y.strike_rate * (1.0 + y.runs_scored / 10.0);

    int victim   = (cost_x <= cost_y) ? cycle[0] : cycle[1];
    int survivor = (victim == cycle[0]) ? cycle[1] : cycle[0];

    string ro_fielder = fielder_names[field_team][randomInt(0, 10)];

    team_batters[bat_team][victim].is_out    = true;
    team_batters[bat_team][victim].at_crease = false;
    team_batters[bat_team][victim].dismissal = "run out (" + ro_fielder + ")";

    int safe_end = (team_batters[bat_team][victim].crease_end == 0) ? 1 : 0;
    team_batters[bat_team][survivor].crease_end = safe_end;

    rag.release(victim);
    rag.acquire(survivor, safe_end);

    pthread_mutex_lock(&log_mutex);
    cout << "  [UMPIRE/DEADLOCK] RAG cycle resolved — run-out!\n";
    cout << "    Victim   (cost=" << fixed << setprecision(1) << cost_x << "): "
         << team_batters[bat_team][victim].name   << "\n";
    cout << "    Survivor (cost=" << fixed << setprecision(1) << cost_y << "): "
         << team_batters[bat_team][survivor].name << "\n";
    cout << "    run out (" << ro_fielder << ")\n";

    cout<<endl;
    cout<<endl;
    pthread_mutex_unlock(&log_mutex);

    pthread_mutex_lock(&score_mutex);
    innings_score[bat_team].wickets++;
    if (innings_score[bat_team].wickets >= 10) {
        match_state.innings_over[bat_team] = true;
        pthread_cond_broadcast(&ball_hit_cond);
    }
    pthread_mutex_unlock(&score_mutex);

    sem_post(&crease_sem);

    pthread_mutex_unlock(&runout_mutex);
    return victim;   // caller must update its striker/non_striker pointer
}

// OVER ARG

struct OverArg {
    int  ti, bti, over, bowler_id;
    int* striker;
    int* non_striker;
    SchedulerMode sched;
    int  target;         
};

// helper: bring next batter to crease after any dismissal

static void bringNextBatter(int bti, int over, int dead_idx,
                             OverArg* oa, const string& sched_str) {
    int ol = TOTAL_OVERS - over - 1;
    int rn = (bti == 1) ? max(0, innings_score[0].runs + 1
                                 - innings_score[1].runs) : 0;
    int nx = selectNextBatter(bti, bti, ol, rn,
                              innings_score[bti].wickets, oa->sched);
    if (nx == -1) return;

    sem_wait(&crease_sem);
    team_batters[bti][nx].arrival_ball = global_ball;
    team_batters[bti][nx].sched_entry  = sched_str;
    team_batters[bti][nx].at_crease    = true;
    team_batters[bti][nx].crease_end   = 0;
    rag.acquire(nx, 0);
    team_batters[bti][nx].wait_balls =
        team_batters[bti][nx].batting_start - team_batters[bti][nx].arrival_ball;

    if (*(oa->striker) == dead_idx)
        *(oa->striker) = nx;
    else
        *(oa->non_striker) = nx;

    pthread_mutex_lock(&log_mutex);
    cout << "  >> " << team_batters[bti][nx].name
         << " comes to crease  (SR="
         << team_batters[bti][nx].strike_rate
         << ", " << team_batters[bti][nx].role
         << ", sched=" << sched_str << ")\n";

    cout<<endl;
    cout<<endl;
    pthread_mutex_unlock(&log_mutex);
}


// BOWLER THREAD — one complete over

void* bowlerThread(void* arg) {
    OverArg* oa  = (OverArg*)arg;
    int ti       = oa->ti;
    int bti      = oa->bti;
    int over     = oa->over;
    int bid      = oa->bowler_id;

    BowlerStats& bowl = team_bowlers[ti][bid];
    int legal_balls = 0, over_runs = 0;

    pthread_mutex_lock(&log_mutex);
    cout << "\nOVER " << (over+1) << "  "
         << bowl.name << "  [" << bowl.type << "]\n";
    pthread_mutex_unlock(&log_mutex);

    while (legal_balls < BALLS_PER_OVER) {

        pthread_mutex_lock(&pitch_mutex);

        if (innings_score[bti].wickets >= 10 || match_state.innings_over[bti] ||
            (oa->target > 0 && innings_score[bti].runs > oa->target)) {
            pthread_mutex_unlock(&pitch_mutex);
            break;
        }

        int s  = *(oa->striker);
        int ns = *(oa->non_striker);

        BatterStats& bat = team_batters[bti][s];

        BallOutcome out = simulateBall(bat, bowl, match_state.free_hit, bti);
        match_state.free_hit = false;

        string ob = to_string(over) + "." + to_string(legal_balls+1);
        int runs_ball = 0;
        string desc = ob + "  " + bat.name + " v " + bowl.name + "  →  ";
        string sched_str = (oa->sched == SJF) ? "SJF" :
                           (oa->sched == PRIORITY) ? "PRIORITY" : "RR";

        if (bat.batting_start == 0 && bat.balls_faced == 0) {
            bat.batting_start = global_ball;
            bat.first_ball_ob = ob;
        }
        bat.last_ball_ob = ob;

        switch (out) {
            case DOT:
                desc += "dot";
                break;

            case SINGLE:
                runs_ball = 1; desc += "1 run";
               
                if (!team_batters[bti][*(oa->striker)].is_out &&
                    !team_batters[bti][*(oa->non_striker)].is_out &&
                     team_batters[bti][*(oa->striker)].at_crease &&
                     team_batters[bti][*(oa->non_striker)].at_crease)
                    swap(*(oa->striker), *(oa->non_striker));
                break;

            case DOUBLE_RUN:
                runs_ball = 2; desc += "2 runs";
                break;

            case TRIPLE:
                runs_ball = 3; desc += "3 runs";
                
                if (!team_batters[bti][*(oa->striker)].is_out &&
                    !team_batters[bti][*(oa->non_striker)].is_out &&
                     team_batters[bti][*(oa->striker)].at_crease &&
                     team_batters[bti][*(oa->non_striker)].at_crease)
                    swap(*(oa->striker), *(oa->non_striker));
                break;

            case FOUR:
                runs_ball = 4; desc += "FOUR!";
                pthread_mutex_lock(&score_mutex);
                match_state.ball_in_air = true;
                pthread_cond_broadcast(&ball_hit_cond);
                match_state.ball_in_air = false;
                pthread_mutex_unlock(&score_mutex);
                break;

            case SIX:
                runs_ball = 6; desc += "SIX!!";
                pthread_mutex_lock(&score_mutex);
                match_state.ball_in_air = true;
                pthread_cond_broadcast(&ball_hit_cond);
                match_state.ball_in_air = false;
                pthread_mutex_unlock(&score_mutex);
                break;

            case WIDE:
                pthread_mutex_lock(&score_mutex);
                innings_score[bti].extras++;
                innings_score[bti].runs++;
                over_runs++; bowl.runs_given++;
                pthread_mutex_unlock(&score_mutex);
                pthread_mutex_unlock(&pitch_mutex);
                pthread_mutex_lock(&log_mutex);
                cout << ob << "  " << bat.name << " v " << bowl.name
                     << "  →  Wide  [" << innings_score[bti].runs
                     << "/" << innings_score[bti].wickets << "]\n";

                cout<<endl;
                cout<<endl;
                pthread_mutex_unlock(&log_mutex);
                continue;

            case NO_BALL:
                match_state.free_hit = true;
                pthread_mutex_lock(&score_mutex);
                innings_score[bti].extras++;
                innings_score[bti].runs++;
                over_runs++; bowl.runs_given++;
                pthread_mutex_unlock(&score_mutex);
                pthread_mutex_unlock(&pitch_mutex);
                pthread_mutex_lock(&log_mutex);
                cout << ob << "  " << bat.name << " v " << bowl.name
                     << "  →  No ball (+1, FREE HIT)  ["
                     << innings_score[bti].runs << "/"
                     << innings_score[bti].wickets << "]\n";

                cout<<endl;
                cout<<endl;
                pthread_mutex_unlock(&log_mutex);
                continue;

            case WICKET: {
                DismissalMode dm  = pickDismissalMode(bowl.type);
                string        dis = makeDismissal(dm, bowl.name, ti);
                bat.dismissal  = dis;
                bat.is_out     = true;
                bat.at_crease  = false;
                rag.release(s);
                sem_post(&crease_sem);
                bowl.wickets_taken++;
                desc += "OUT!  " + bat.name + "  " + dis;
                pthread_mutex_lock(&score_mutex);
                innings_score[bti].wickets++;
                pthread_mutex_unlock(&score_mutex);
                break;
            }
        }

        pthread_mutex_lock(&score_mutex);
        innings_score[bti].runs       += runs_ball;
        innings_score[bti].balls_faced++;
        over_runs    += runs_ball;
        bowl.runs_given += runs_ball;
        bat.runs_scored += runs_ball;
        bat.balls_faced++;
        global_ball++;
        pthread_mutex_unlock(&score_mutex);

        string outcome_str = (runs_ball == 0 && out != WICKET) ? "dot" :
                             (out == WICKET) ? "OUT" :
                             (out == FOUR)   ? "FOUR" :
                             (out == SIX)    ? "SIX"  :
                             to_string(runs_ball) + "run";
        pthread_mutex_lock(&gantt_mutex);
        gantt_log.push_back({(int)gantt_log.size()+1, ob, bat.name,
                             bowl.name, outcome_str, sched_str});
        pthread_mutex_unlock(&gantt_mutex);

        legal_balls++;
        desc += "  [" + to_string(innings_score[bti].runs)
              + "/" + to_string(innings_score[bti].wickets) + "]";

        pthread_mutex_lock(&log_mutex);
        cout << desc << "\n";
        pthread_mutex_unlock(&log_mutex);

        pthread_mutex_unlock(&pitch_mutex);


        if (out == WICKET && innings_score[bti].wickets < 10) {
            bringNextBatter(bti, over, s, oa, sched_str);
        }

        // 5% run-out on running balls
      
        if ((out == SINGLE || out == DOUBLE_RUN || out == TRIPLE)
            && randomInt(1,20) == 1) {
            int victim = checkRunOut(bti, s, ns, ti);
            if (victim != -1 && innings_score[bti].wickets < 10) {
                bringNextBatter(bti, over, victim, oa, sched_str);
            }
        }

        usleep(25000);
    }

    bowl.saved_balls  = legal_balls;
    bowl.overs_bowled++;
    bowl.economy = bowl.overs_bowled > 0
                 ? (double)bowl.runs_given / bowl.overs_bowled : 0.0;
    match_state.last_over_runs = over_runs;

    delete oa;
    return nullptr;
}


// INNINGS SIMULATOR

struct InningsArg { int bat_team; int bowl_team; int target; int schd; };

void* simulateInnings(void* arg) {
    InningsArg* ia = (InningsArg*)arg;
    int schd = ia->schd;
    int bti = ia->bat_team, ti = ia->bowl_team, target = ia->target;
    string bn = (bti==0)?"India":"New Zealand";

    queue<int> q_normal, q_econ, q_wick;
    for (int i = 0; i < NUM_BOWLERS; i++) {
        string t = team_bowlers[ti][i].type;
        if      (t=="normal") q_normal.push(i);
        else if (t=="econ")   q_econ.push(i);
        else                  q_wick.push(i);
    }
    map<int,int> ovb;

    SchedulerMode sched;
    if (schd == 0)
        sched = ROUND_ROBIN;
    else
        sched = SJF;

    
    int striker = selectNextBatter(bti, bti, TOTAL_OVERS, 0, 0, sched);
    team_batters[bti][striker].at_crease  = true;
    team_batters[bti][striker].crease_end = 0;
    team_batters[bti][striker].sched_entry = (sched==SJF)?"SJF":"RR";
    rag.acquire(striker, 0);

    int non_striker = selectNextBatter(bti, bti, TOTAL_OVERS, 0, 0, sched);
    team_batters[bti][non_striker].at_crease  = true;
    team_batters[bti][non_striker].crease_end = 1;
    team_batters[bti][non_striker].sched_entry = (sched==SJF)?"SJF":"RR";
    rag.acquire(non_striker, 1);

    sem_init(&crease_sem, 0, 0);

    pthread_mutex_lock(&log_mutex);
    cout << "  INNINGS " << (bti+1) << "  |  " << bn << " batting\n";
    if (target > 0)
        cout << "  TARGET: " << target << " runs in " << TOTAL_OVERS << " overs\n";

    cout<<"\n";
    cout<<"\n";
    pthread_mutex_unlock(&log_mutex);

    pthread_t fielder_threads[NUM_FIELDERS];
    for (int f = 0; f < NUM_FIELDERS; f++) {
        FielderArg* fa = new FielderArg{f, bti};
        pthread_create(&fielder_threads[f], nullptr, fielderThread, fa);
    }

    for (int over = 0; over < TOTAL_OVERS; over++) {
        if (innings_score[bti].wickets >= 10 || match_state.innings_over[bti]) break;
        if (target > 0 && innings_score[bti].runs >= target)                   break;

        BowlerQueue qt = computeThreatQueue(match_state.last_over_runs);
        int bid = -1;
        
if (over >= 14 && bid == -1) {

    auto pick = [&](queue<int>& q) -> int {
        int n = (int)q.size();
        while (n-- > 0) {
            int f = q.front(); q.pop();
            if (ovb[f] < 4) { q.push(f); return f; }
            q.push(f);
        }
        return -1;
    };

    bid = pick(q_wick);     
    if (bid == -1)
        bid = pick(q_econ); 

    if (bid == -1)
        bid = pick(q_normal); 
}
        if (bid == -1) {
            auto pick = [&](queue<int>& q) -> int {
                int n = (int)q.size();
                while (n-- > 0) {
                    int f = q.front(); q.pop();
                    if (ovb[f] < 4) { q.push(f); return f; }
                    q.push(f);
                }
                return -1;
            };
            if      (qt==Q_NORMAL) bid = pick(q_normal);
            else if (qt==Q_ECON)   bid = pick(q_econ);
            else                   bid = pick(q_wick);
        }
        if (bid == -1)
            for (int i=0;i<NUM_BOWLERS;i++) if (ovb[i]<4){ bid=i; break; }
        if (bid == -1) {
            pthread_mutex_lock(&log_mutex);
            cout << "[WARN] No bowler for over " << (over+1) << "\n";
            pthread_mutex_unlock(&log_mutex);
            break;
        }
        ovb[bid]++;

        OverArg* oa = new OverArg{ti, bti, over, bid, &striker, &non_striker, sched,target};
        pthread_t bt;
        pthread_create(&bt, nullptr, bowlerThread, oa);
        pthread_join(bt, nullptr);

         
        string sched_name = (sched==ROUND_ROBIN)?"RR":(sched==SJF)?"SJF":"PRIORITY";
        string qname = (computeThreatQueue(match_state.last_over_runs)==Q_NORMAL)?"NORMAL":
                       (computeThreatQueue(match_state.last_over_runs)==Q_ECON)  ?"ECON":"WICKET";
        pthread_mutex_lock(&log_mutex);
        cout << "  [CONTEXT SWITCH] " << team_bowlers[ti][bid].name
             << "  over_runs=" << match_state.last_over_runs
             << "  scheduler=" << sched_name
             << "  next_queue=" << qname << "\n";

        cout<<"\n";
        pthread_mutex_unlock(&log_mutex);

        swap(striker, non_striker);
    }

    pthread_mutex_lock(&score_mutex);
    match_state.innings_over[bti] = true;
    pthread_cond_broadcast(&ball_hit_cond);
    pthread_mutex_unlock(&score_mutex);
    for (int f=0;f<NUM_FIELDERS;f++) pthread_join(fielder_threads[f], nullptr);

    int tb = innings_score[bti].balls_faced;
    pthread_mutex_lock(&log_mutex);
    cout << "  " << bn << "  "
         << innings_score[bti].runs << "/" << innings_score[bti].wickets
         << "  (" << tb/6 << "." << tb%6 << " ov)"
         << "  Extras: " << innings_score[bti].extras << "\n";
    cout << "\n  BATTING\n";
    cout << "  " << string(62,'-') << "\n";

    cout<<endl;
    cout<<endl;
    for (int i=0;i<NUM_BATTERS;i++) {
        BatterStats& b = team_batters[bti][i];
        if (b.balls_faced == 0 && !b.at_crease) continue;
        string status = b.is_out ? b.dismissal : "not out";
        cout << "  " << left  << setw(12) << b.name
             << right << setw(5)  << b.runs_scored
             << "  (" << setw(3) << b.balls_faced << "b)  "
             << left  << status << "\n";
        
        cout<<endl;
        cout<<endl;     
    }
    cout << "\n  BOWLING\n";
    cout << "  " << string(42,'-') << "\n";
    cout << "  " << left << setw(12) << "Bowler"
         << setw(5) << "O" << setw(5) << "R" << setw(5) << "W" << "  Eco\n";

    cout<<endl;
    cout<<endl;
    for (int i=0;i<NUM_BOWLERS;i++) {
        BowlerStats& bw = team_bowlers[ti][i];
        if (bw.overs_bowled == 0) continue;
        cout << "  " << left  << setw(12) << bw.name
             << right << setw(3) << bw.overs_bowled
             << setw(6) << bw.runs_given
             << setw(5) << bw.wickets_taken
             << "  " << fixed << setprecision(2) << bw.economy << "\n";

        cout<<endl;
        cout<<endl;
    }
    pthread_mutex_unlock(&log_mutex);

    match_state.innings_done[bti] = true;
    delete ia;
    return nullptr;
}




void printDotGanttChart() {
    cout << "   DOT GANTT CHART (Each dot = 1 ball)\n";
    int total = gantt_log.size();
    cout << "Balls 1 to " << total << "\n";

    vector<string> order;
    unordered_map<string, string> batter_line;

    for (auto &g : gantt_log) {
        if (batter_line.find(g.batter) == batter_line.end()) {
            order.push_back(g.batter);
            batter_line[g.batter] = "";
        }
        batter_line[g.batter].resize(g.ball_number - 1, ' ');
        batter_line[g.batter] += ".";
    }

    for (auto &name : order) {
        cout << setw(12) << left << name << ": " << batter_line[name] << "\n";

        cout<<endl;
        cout<<endl;
    }

    cout << "\nLegend: '.' = batter faced that ball\n";
    cout<<endl;
    cout<<endl;
}




void printWaitTimeAnalysis(int bat_first) {
    cout << "   SCHEDULING ANALYSIS — WAIT TIME\n";
    cout << "   SJF or FCFS is used to schedule batsmen of both teams\n";

    string teams[2] = {"India", "New Zealand"};
    for (int t = 0; t < 2; t++) {
        cout << "\n  " << teams[t] << ":\n";
        cout << "  " << left << setw(12) << "Batter"
             << setw(10) << "Role"
             << setw(12) << "Arrival(b)"
             << setw(12) << "Start(b)"
             << setw(10) << "Wait(b)"
             << "SJF_burst\n";
        cout << "  " << string(58, '-') << "\n";


        cout<<endl;
        cout<<endl;
        double total_wait = 0; int count = 0;
        for (int i = 2; i <= 6; i++) {
            BatterStats& b = team_batters[t][i];
            if (b.balls_faced == 0 && b.arrival_ball == 0) continue;
            int wait = max(0, b.batting_start - b.arrival_ball);
            total_wait += wait; count++;
            cout << "  " << left  << setw(12) << b.name
                 << setw(10) << b.role
                 << right << setw(10) << b.arrival_ball
                 << setw(12) << b.batting_start
                 << setw(10) << wait
                 << "  " << fixed << setprecision(1) << b.sjf_burst() << "\n";
            cout<<endl;
            cout<<endl;
        }
        if (count > 0)
            cout << "  Avg middle-order wait: "
                 << fixed << setprecision(2) << total_wait/count << " balls\n";

                 cout<<endl;
                 
                 cout<<endl;
    }

    cout << "\n  NOTE: Under pure SJF, batters with lower batting_avg\n";
    cout << "  (shorter burst estimate) are sent in first during overs 7-14.\n";
    cout << "  Under FCFS, batting order is strictly maintained.\n";
    cout << "  Lower avg wait = better CPU utilisation of the PITCH resource.\n";
}

void printResult(int bat_first) {
    string teams[2] = {"India","New Zealand"};
    int t1 = innings_score[bat_first].runs;
    int t2 = innings_score[1-bat_first].runs;
    int w2 = innings_score[1-bat_first].wickets;
    
    cout << "     2026 ICC T20 WORLD CUP FINAL — RESULT\n";
    cout << "  " << teams[bat_first]   << " (bat 1st): " << t1 << "\n";
    cout << "  " << teams[1-bat_first] << " (chasing): " << t2 << "/" << w2 << "\n";
    
    if      (t2 > t1) cout << "  " << teams[1-bat_first] << " WON by " << (10-w2) << " wicket(s)!\n";
    else if (t1 > t2) cout << "  " << teams[bat_first]   << " WON by " << (t1-t2) << " run(s)!\n";
    else              cout << "  MATCH TIED — Super Over!\n";
    
}




