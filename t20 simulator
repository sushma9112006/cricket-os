// BATTER SELECTION ENGINE

int selectNextBatter(int team_idx, int bti, int overs_left,
                     int runs_needed, int wkts, SchedulerMode sched) {
    double rrr;
    if (bti == 0) {
        int still_needed = max(0, 200 - innings_score[0].runs);
        rrr = (overs_left > 0) ? (double)still_needed / overs_left : 999.0;
    } else {
        rrr = (overs_left > 0) ? (double)runs_needed / overs_left : 999.0;
    }

    if (sched == SJF) {
        int    best_id    = -1;
        double best_burst = 1e9;
        for (int i = 0; i < NUM_BATTERS; i++) {
            BatterStats& b = team_batters[team_idx][i];
            if (b.is_out || b.at_crease) continue;
            if (b.sjf_burst() < best_burst) {
                best_burst = b.sjf_burst();
                best_id    = i;
            }
        }
        if (best_id == -1) {
            for (int i = 0; i < NUM_BATTERS; i++) {
                BatterStats& b = team_batters[team_idx][i];
                if (!b.is_out && !b.at_crease) { best_id = i; break; }
            }
        }
        return best_id;
    }
    else if (sched == ROUND_ROBIN) {
        for (int i = 0; i < NUM_BATTERS; i++) {
            BatterStats& b = team_batters[team_idx][i];
            if (!b.is_out && !b.at_crease) {
                return i;
            }
        }
    }
    return -1;
}


