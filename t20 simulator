//RESOURCE ALLOCATION GRAPH  (run-out deadlock detection)

struct RAG {
    int held[NUM_BATTERS];
    int want[NUM_BATTERS];
    pthread_mutex_t mu;

    void init() {
        memset(held, -1, sizeof(held));
        memset(want, -1, sizeof(want));
        pthread_mutex_init(&mu, nullptr);
    }
    void destroy() { pthread_mutex_destroy(&mu); }

    void acquire(int id, int end) {
        pthread_mutex_lock(&mu);
        held[id] = end; want[id] = -1;
        pthread_mutex_unlock(&mu);
    }
    void release(int id) {
        pthread_mutex_lock(&mu);
        held[id] = -1; want[id] = -1;
        pthread_mutex_unlock(&mu);
    }
    void request(int id, int end) {
        pthread_mutex_lock(&mu);
        want[id] = end;
        pthread_mutex_unlock(&mu);
    }

    bool detectCycle(int cycle[2]) {
        pthread_mutex_lock(&mu);
        for (int i = 0; i < NUM_BATTERS; i++) {
            if (held[i] < 0 || want[i] < 0) continue;
            for (int j = 0; j < NUM_BATTERS; j++) {
                if (i == j || held[j] < 0) continue;
                if (held[i] != want[j] || held[j] != want[i]) continue;
                cycle[0] = i; cycle[1] = j;
                pthread_mutex_unlock(&mu);
                return true;
            }
        }
        for (int end = 0; end <= 1; end++) {
            int first = -1;
            for (int i = 0; i < NUM_BATTERS; i++) {
                if (held[i] != end) continue;
                if (first == -1) { first = i; }
                else { cycle[0] = first; cycle[1] = i;
                       pthread_mutex_unlock(&mu); return true; }
            }
        }
        pthread_mutex_unlock(&mu);
        return false;
    }
} rag;


