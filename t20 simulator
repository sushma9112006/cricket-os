    int target = innings_score[bf].runs + 1;

    sem_destroy(&crease_sem);

    for (int i = 0; i < NUM_BATTERS; i++) {
        rag.held[i] = -1;
        rag.want[i] = -1;
    }

    for (int i=0;i<NUM_BATTERS;i++) {
        auto& b = team_batters[bowl_first][i];
        b.is_out=false; b.at_crease=false; b.crease_end=-1;
