// BALL OUTCOME

BallOutcome simulateBall(const BatterStats& bat, const BowlerStats& bowl,
                         bool free_hit, int bti) {
    vector<int> w = {20, 33, 11, 3, 15, 7, 4, 2, 5};

    if      (bat.strike_rate >= 155) { w[4]+=3; w[5]+=2; w[0]-=3; }
    else if (bat.strike_rate >= 140) { w[4]+=2; w[5]+=1; w[0]-=2; }
    else if (bat.strike_rate <= 95 ) { w[0]+=4; w[4]-=2; w[5]-=2; w[8]+=2; }
    else if (bat.strike_rate <= 115) { w[0]+=2; w[4]-=1; w[8]+=1; }

    if      (bowl.type=="wicket") { w[8]+=3; w[0]+=2; w[4]-=1; }
    else if (bowl.type=="econ")   { w[0]+=2; w[4]-=2; w[5]-=1; }
    else                          { w[1]+=1; w[4]+=1; }

    int balls_done = innings_score[bti].balls_faced;
    int runs_live  = innings_score[bti].runs;
    int wkts_live  = innings_score[bti].wickets;
    const int TMIN = 130, TMAX = 230;

    if (balls_done >= 6) {
        double rpb       = (double)runs_live / balls_done;
        int    projected = (int)(rpb * 120);

        if (wkts_live < 7) {
            if      (projected > TMAX + 30) { w[8]+=8; w[0]+=7; w[4]-=5; w[5]-=4; }
            else if (projected > TMAX + 15) { w[8]+=5; w[0]+=5; w[4]-=3; w[5]-=2; }
            else if (projected > TMAX)      { w[8]+=3; w[0]+=3; w[4]-=2; }
            else if (projected < TMIN - 20) { w[8]-=6; w[0]-=6; w[4]+=5; w[5]+=4; }
            else if (projected < TMIN)      { w[8]-=3; w[0]-=3; w[4]+=3; w[5]+=2; }
        } else {
            if (projected > TMAX) { w[8]+=4; w[0]+=3; w[4]-=2; }
        }
    }

    if (balls_done <= 10 && wkts_live >= 3) {
        w[8] -= 5; w[0] -= 4; w[4] += 4; w[5] += 2;
    }

    if (wkts_live >= 9)      { w[8]+=5; w[0]+=4; w[4]-=2; w[5]-=2; }
    else if (wkts_live >= 7) { w[8]+=3; w[0]+=2; w[4]-=1; w[5]-=1; }

    for (auto& x : w) x = max(x, 1);
    w[4] = min(w[4], 20); w[5] = min(w[5], 12);
    w[8] = min(w[8], 20); w[0] = min(w[0], 35);

    if (free_hit) w[8] = 0;

    discrete_distribution<int> dist(w.begin(), w.end());
    return static_cast<BallOutcome>(dist(rng_engine));
}

